# Server
PORT=3001

# Comma-separated CORS allowed origins (frontend URLs)
# In dev: defaults to http://localhost:5173,http://localhost:4173
# In production: set to your frontend domain
#   CORS_ORIGIN=https://tradeai.vercel.app
CORS_ORIGIN=

# Legacy external stock API (unused by new market service)
STOCK_API_BASE_URL=http://your-stock-api-host

# In-memory cache TTL (seconds)
CACHE_TTL_SECONDS=30

# Express rate limiter (requests per minute)
RATE_LIMIT_PER_MINUTE=30

# NSE Provider
NSE_RATE_LIMIT_RPS=3
NSE_TIMEOUT_MS=15000

# BSE Provider
BSE_RATE_LIMIT_RPS=8
BSE_TIMEOUT_MS=10000

# Yahoo Finance fallback
YAHOO_FINANCE_ENABLED=true

# Upstox provider (primary market data)
UPSTOX_ENABLED=true
UPSTOX_ACCESS_TOKEN=
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_RATE_LIMIT_RPS=5
UPSTOX_TIMEOUT_MS=10000

# Stooq fallback (free CSV stock data, no API key needed)
STOOQ_ENABLED=true

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RESET_MS=30000

# LLM Multi-Provider Chain
# Groq (fastest, free tier available)
GROQ_API_KEY=
# Google Gemini (free tier available)
GEMINI_API_KEY=
# LLM request timeout per provider (ms)
LLM_TIMEOUT_MS=30000

# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
