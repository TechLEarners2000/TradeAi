# Frontend environment variables (Vite)
# In development (Vite proxy), leave empty — /api → localhost:3001
# In production (Vercel/Netlify), set to your backend root URL (no trailing slash)
#   VITE_API_HOST=https://tradeai-backend.onrender.com
#   → frontend fetches from https://tradeai-backend.onrender.com/api/stock/...
VITE_API_HOST=
